---
const { title = "Tom’s Transmission Service", children } = Astro.props;
---

<html lang="en">
  <head>
    <title>{title}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  </head>
  <body class="bg-white text-gray-900 font-sans">
    <header class="bg-gray-900 text-white px-6 py-4 flex justify-between items-center">
      <a href="/" class="text-xl font-bold">Tom’s Transmission</a>
      <nav class="space-x-6">
        <a href="/services" class="hover:text-blue-400">Services</a>
        <a href="/media" class="hover:text-blue-400">Media</a>
        <a href="/about" class="hover:text-blue-400">About</a>
        <a href="/login" class="bg-blue-600 hover:bg-blue-700 px-4 py-2 rounded text-white font-semibold">Login</a>
      </nav>
    </header>

    <main class="px-6 py-10 max-w-6xl mx-auto">
      {children}
    </main>
  </body>
</html>
