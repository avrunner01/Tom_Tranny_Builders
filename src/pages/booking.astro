---
import '/src/styles/index.css';
import BackButton from "../components/BackButton.astro";
---

<link href="./src/output.css" rel="stylesheet">

<form name="transmission-booking" method="POST" data-netlify="true">
  <input type="hidden" name="form-name" value="transmission-booking" />
  <!-- your form fields go here -->
</form>

<form name="transmission-booking" method="POST" data-netlify="true" class="max-w-xl mx-auto p-6 bg-white shadow-md rounded-md space-y-6">
  <h2 class="text-2xl font-bold text-gray-800">Schedule Your Service</h2>

  <div>
    <label for="name" class="block text-sm font-medium text-gray-700">Full Name</label>
    <input type="text" id="name" name="name" required class="mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500" />
  </div>

  <div>
    <label for="email" class="block text-sm font-medium text-gray-700">Email Address</label>
    <input type="email" id="email" name="email" required class="mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500" />
  </div>

  <div>
    <label for="phone" class="block text-sm font-medium text-gray-700">Phone Number</label>
    <input type="tel" id="phone" name="phone" required class="mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500" />
  </div>

  <div>
    <label for="vehicle" class="block text-sm font-medium text-gray-700">Vehicle Make & Model</label>
    <input type="text" id="vehicle" name="vehicle" placeholder="e.g. 2002 Chevy Avalanche" required class="mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500" />
  </div>

  <div>
    <label for="service" class="block text-sm font-medium text-gray-700">Service Needed</label>
    <select id="service" name="service" required class="mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500">
      <option value="">Select a service</option>
      <option value="diagnostics">Transmission Diagnostics</option>
      <option value="rebuild">Rebuild / Replacement</option>
      <option value="flush">Fluid Flush & Filter</option>
      <option value="tuning">Performance Tuning</option>
      <option value="clutch">Clutch & Flywheel Service</option>
    </select>
  </div>

  <div>
    <label for="date" class="block text-sm font-medium text-gray-700">Preferred Appointment Date</label>
    <input type="date" id="date" name="date" required class="mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500" />
  </div>

  <div>
    <label for="notes" class="block text-sm font-medium text-gray-700">Additional Notes</label>
    <textarea id="notes" name="notes" rows="4" placeholder="Tell us more about your build or issue…" class="mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500"></textarea>
  </div>

  <BackButton />

  <button type="submit" class="w-full bg-blue-600 text-white py-2 px-4 rounded-md hover:bg-blue-700 transition">Book Now</button>
</form>

