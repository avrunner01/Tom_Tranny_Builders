---
import '/src/styles/index.css';
import BackButton from "../components/BackButton.astro";
import HotRodGallery from '../pages/HotRodGallery.astro';
import Layout from '../layouts/Layout.astro';


const site = Astro.site
const { title } = Astro.props

const pageTitle = "Media Tom's Transmission Service";
const gallery = [
  { src: "/images/front_building.jpg", alt: "Shop exterior", caption: "Our San Tan Valley location" },
  { src: "/images/BB396.jpg", alt: "Engine rebuild", caption: "Precision 396 BBC rebuild in progress" },
  { src: "/images/drivetrain.jpg", alt: "Classic Chevelle", caption: "Custom drivetrain install on a 67 Chevelle"},
];

const videos = [];
---

<Layout title="Media Tom's Transmission Service">
<link href="./src/output.css" rel="stylesheet">
 
 <body class="bg-conic-120 text-black text-center">
    <section class="flex flex-col items-center min-h-screen">
		 <img src="/logos/challenger_blown_motor.jpg" alt="mopar logo" class="w-60 h-auto p-3" />
  </body>

<section class="p-1" style="text-align: center;">
  <h1 class="text-5xl font-semibold p-15 text-shadow-cyan-400">Media Center</h1>
 </section>

  <BackButton />
  
 <HotRodGallery/>

  <BackButton />
  
<html lang="en">
  <head>
    <title>{pageTitle}</title>
    <meta name="description" content="Explore photos, videos, and press coverage from Tom's Transmission Service in Arizona." />
  </head>
     <body style="background-color: #33cb1e95;">
    <main class="max-w-6xl mx-auto px-6 py-16 text-black text-center">
      <h1 class="text-4xl font-bold mb-5 text-black text-center">Media Gallery</h1>

      <section class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6 mb-16">
        {gallery.map((item) => (
          <div class="rounded overflow-hidden shadow">
            <img src={item.src} alt={item.alt} class="w-full h-48 object-cover" />
            <div class="p-4 text-sm text-gray-700">{item.caption}</div>
          </div>
        ))}
      </section>
      
      <h2 class="text-4xl font-semibold mb-6 text-black text-center">Shop Videos</h2>
      <section class="space-y-10">
        {videos.map((video) => (
          <div>
            <h3 class="text-xl font-medium mb-2">{video.title}</h3>
            <div class="aspect-video">
              <iframe src={video.url} frameborder="0" allowfullscreen class="w-full h-full"></iframe>
            </div>
          </div>
        ))}
      </section>

      <div class="video-card">
      <h3>Unit Teardown: Phase 1</h3>
      <video controls preload="metadata" poster="images/teardown-thumb.jpg">
        <source src="https://storage.googleapis.com/tom_tranny/Tranny_teardown_1.mp4" type="video/mp4">
        Your browser does not support the video tag.
      </video>
      <p>Detailed inspection of the gear set and clutches.</p>
    </div>

    <div class="video-card">
      <h3>Unit Teardown: Phase 2</h3>
      <video controls preload="metadata" poster="images/teardown-thumb.jpg">
        <source src="https://storage.googleapis.com/tom_tranny/Tranny_teardown_2.mp4" type="video/mp4">
        Your browser does not support the video tag.
      </video>
      <p>Detailed inspection of the gear set and clutches.</p>
    </div>

    <div class="video-card">
      <h3>Unit Teardown: Phase 3</h3>
      <video controls preload="metadata" poster="images/teardown-thumb.jpg">
        <source src="https://storage.googleapis.com/tom_tranny/Tranny_teardown_3.mp4" type="video/mp4">
        Your browser does not support the video tag.
      </video>
      <p>Detailed inspection of the gear set and clutches.</p>
    </div>
 
    <div class="video-card">
      <h3>Unit Teardown: Phase 4</h3>
      <video controls preload="metadata" poster="images/teardown-thumb.jpg">
        <source src="https://storage.googleapis.com/tom_tranny/Tranny_teardown_4.mp4" type="video/mp4">
        Your browser does not support the video tag.
      </video>
      <p>Detailed inspection of the gear set and clutches.</p>
    </div>

    <div class="video-card">
      <h3>Unit Teardown: Phase 5</h3>
      <video controls preload="metadata" poster="images/teardown-thumb.jpg">
        <source src="https://storage.googleapis.com/tom_tranny/Tranny_teardown_5.mp4" type="video/mp4">
        Your browser does not support the video tag.
      </video>
      <p>Detailed inspection of the gear set and clutches.</p>
    </div>

    <div class="video-card">
      <h3>Unit Teardown: Phase 6</h3>
      <video controls preload="metadata" poster="images/teardown-thumb.jpg">
        <source src="https://storage.googleapis.com/tom_tranny/Tranny_teardown_6.mp4" type="video/mp4">
        Your browser does not support the video tag.
      </video>
      <p>Detailed inspection of the gear set and clutches.</p>
    </div>

    <BackButton />

   
      <h2 class="text-3xl font-semibold mt-16 mb-6">In the Press</h2>
      <ul class="list-disc list-inside space-y-2 text-gray-700">
        <li><a href="https://moparconnectionmagazine.com/" class="text-blue-600 hover:underline">Mopar Magazine</a></li>
        <li><a href="https://www.hotrod.com/" class="text-blue-600 hover:underline">"Inside Tom's 69 Challenger Build</a></li>
      </ul>
    </main>
  </body>
 </html>
  </Layout>
